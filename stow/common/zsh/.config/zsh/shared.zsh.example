# shared.zsh.example — portable zsh config (macOS + Arch)
# Copy to shared.zsh, review, then stow. Do NOT stow this .example directly.
# All YOUR_* tokens are literal placeholders, not shell variables.
#
# SAFETY: every tool line below is GUARDED — it activates an already-installed tool and
# is a no-op when the tool is absent. Nothing here installs a tool, clones a repo, or
# performs a network operation at shell startup.

# --- XDG base directories ---
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# --- Portable environment ---
# Replace YOUR_EDITOR / YOUR_PAGER with your preferred tools (e.g. vim, less).
export EDITOR="YOUR_EDITOR"
export PAGER="YOUR_PAGER"

# --- History ---
# HISTFILE uses $HOME/.zsh_history — safe default that avoids XDG_STATE_HOME complexity.
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=10000
export SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY

# --- Shell options (portable) ---
setopt AUTO_CD

# --- Zinit (plugin manager) — guarded SOURCE only; NEVER cloned at startup (ADR-0020) ---
# Install once, manually (see docs/zsh-migration.md / docs/shell-dependencies.md):
#   git clone https://github.com/zdharma-continuum/zinit.git \
#     "${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
# The line below only sources Zinit if it is already installed; if absent it is a no-op.
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
[[ -f "${ZINIT_HOME}/zinit.zsh" ]] && source "${ZINIT_HOME}/zinit.zsh"

# --- Completion ---
# Ordering note: Zinit initializes completions when it loads. To avoid a double
# `compinit`, run our own standalone compinit ONLY when Zinit is not present/loaded.
if ! typeset -f zinit >/dev/null 2>&1; then
  autoload -Uz compinit && compinit
fi

# --- Tool integrations (guarded — no-op when the tool is missing; never installs) ---
# fzf: key bindings + completion (modern fzf provides `fzf --zsh`).
command -v fzf    >/dev/null 2>&1 && eval "$(fzf --zsh)"
# zoxide: smarter cd.
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
# eza: ls replacement (alias only).
command -v eza    >/dev/null 2>&1 && alias ls='eza'

# --- Portable aliases (flags valid on both BSD and GNU) ---
alias grep='grep --color=auto'

# --- Optional: Oh My Posh prompt integration ---
# Oh My Posh is a prompt engine (NOT Oh My Zsh — it has no plugin manager).
# Prefer the dedicated omp.zsh snippet (sourced by index.zsh) over enabling it here.
# Requires: oh-my-posh installed, a Nerd Font in your terminal, ~/.config/omp/omp.toml
# See stow/common/omp/ for the config template and docs/stow-usage.md for setup steps.
#
# To activate inline instead, copy this block to your real shared.zsh and uncomment:
# if command -v oh-my-posh >/dev/null 2>&1 && [[ -f "$HOME/.config/omp/omp.toml" ]]; then
#   eval "$(oh-my-posh init zsh --config "$HOME/.config/omp/omp.toml")"
# fi

# NOTE: No tool INSTALL, no clone, no network here. No Homebrew, pacman/yay, pbcopy/open,
# or systemctl — those platform-specific bits belong in macos.zsh / arch.zsh. Tool lines
# above only ACTIVATE already-installed tools behind existence guards.
